{
  "name": "a-cool-little-chat",
  "version": "1.0.2",
  "description": "P2P LAN chat",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npx electron-builder"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "active-win": "7.7.2"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "ms": "^2.1.3"
  },
  "build": {
    "appId": "com.lanchat.app",
    "productName": "A Cool Little Chat",
    "compression": "store",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "node_modules/**"
    ],
    "win": {
      "target": {
        "target": "portable",
        "arch": ["x64"]
      },
      "requestedExecutionLevel": "asInvoker"
    }
  }
}
